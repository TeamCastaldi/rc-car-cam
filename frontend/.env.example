# Base URL of the backend streaming server this SPA talks to
PUBLIC_API_BASE_URL=http://localhost:8080

# Shared-secret token sent with stream requests — must match the backend's
# STREAM_AUTH_TOKEN. This is embedded in the client bundle (hence the
# PUBLIC_ prefix); it's not a secret once the page loads, only a barrier
# against casual/accidental access to the stream.
PUBLIC_STREAM_AUTH_TOKEN=changeme
