# Port the streaming server listens on
PORT=8080

# Shared-secret token required to access the video stream / control endpoints.
# NOT YET ENFORCED — the backend doesn't read this yet (see CLAUDE.md's "Not
# started" list: auth for the stream/control endpoints). Left commented out so
# it isn't mistaken for active protection. Generate your own value and put it
# in backend/.env (gitignored) — never commit a real one — once auth lands.
# STREAM_AUTH_TOKEN=changeme
